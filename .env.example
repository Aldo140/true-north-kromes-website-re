# Contact form email delivery (required — form returns an error without it)
# Get a free key at https://resend.com after verifying tnkromes.ca as a sending domain.
RESEND_API_KEY=
# Where contact-form leads get sent. Defaults to truenorthkromes@gmail.com if unset.
CONTACT_LEAD_EMAIL=
# Cc'd on every lead. Defaults to jorti104@mtroyal.ca if unset.
CONTACT_LEAD_CC=
# Must be an address on a domain verified in Resend. The shared resend.dev
# sender is testing-only and generally sends only to the Resend account owner.
# Production format: True North Kromes Website <website@tnkromes.ca>
CONTACT_LEAD_FROM=

# Analytics (optional — CTA tracking silently no-ops until this is set)
NEXT_PUBLIC_GA_MEASUREMENT_ID=
