# Contact form email delivery (required — form returns an error without it)
# Get a free key at https://resend.com after verifying tnkromes.ca as a sending domain.
RESEND_API_KEY=
# Where contact-form leads get sent. Defaults to truenorthkromes@gmail.com if unset.
CONTACT_LEAD_EMAIL=
# Must be an address on a domain verified in Resend. Defaults to Resend's shared
# onboarding sender, which is fine to start but looks less trustworthy in inboxes.
CONTACT_LEAD_FROM=

# Analytics (optional — CTA tracking silently no-ops until this is set)
NEXT_PUBLIC_GA_MEASUREMENT_ID=
